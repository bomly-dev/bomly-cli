{
  "name": "demo-workspace",
  "version": "1.0.0",
  "lockfileVersion": 3,
  "packages": {
    "": {
      "name": "demo-workspace",
      "version": "1.0.0",
      "workspaces": ["apps/*", "packages/*"],
      "dependencies": {
        "lodash": "^4.17.21"
      }
    },
    "apps/web": {
      "name": "web",
      "version": "0.2.0",
      "dependencies": {
        "shared-transitive": "^2.0.0",
        "lib": "1.0.0"
      },
      "devDependencies": {
        "member-dev-tool": "^3.1.0"
      }
    },
    "packages/lib": {
      "name": "lib",
      "version": "1.0.0",
      "license": "MIT",
      "dependencies": {
        "shared-transitive": "^2.0.0"
      }
    },
    "node_modules/web": {
      "resolved": "apps/web",
      "link": true
    },
    "node_modules/lib": {
      "resolved": "packages/lib",
      "link": true
    },
    "node_modules/lodash": {
      "version": "4.17.21",
      "resolved": "https://registry.npmjs.org/lodash/-/lodash-4.17.21.tgz",
      "license": "MIT"
    },
    "node_modules/shared-transitive": {
      "version": "2.0.0",
      "resolved": "https://registry.npmjs.org/shared-transitive/-/shared-transitive-2.0.0.tgz",
      "license": "MIT"
    },
    "node_modules/member-dev-tool": {
      "version": "3.1.0",
      "resolved": "https://registry.npmjs.org/member-dev-tool/-/member-dev-tool-3.1.0.tgz",
      "dev": true,
      "license": "MIT"
    }
  }
}
